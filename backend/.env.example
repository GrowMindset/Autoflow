DATABASE_NAME=your_database_name
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgresql+asyncpg://${USERNAME}:${PASSWORD}@localhost:5432/${DNAME}
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=${REDIS_URL}
SECRET_KEY=your_secret_key_for_creating_JWT_token
ALGORITHM=your_algorithm_name


# installation command for redis server
# from dockrun command
# docker run -d -p 6379:6379 redis
# or
# docker run -d --name autoflow-redis -p 6379:6379 redis:7

