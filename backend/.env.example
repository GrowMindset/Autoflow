DATABASE_NAME=your_database_name
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgresql+asyncpg://${USERNAME}:${PASSWORD}@localhost:5432/${DNAME}
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_WORKFLOW_QUEUE=workflow.executions
CELERY_NODE_TEST_QUEUE=workflow.node_tests
CELERY_SYSTEM_QUEUE=system
CELERY_VISIBILITY_TIMEOUT=21600
EXECUTION_STALE_TIMEOUT_MINUTES=30
SECRET_KEY=your_secret_key_for_creating_JWT_token
ALGORITHM=your_algorithm_name
OPENAI_API_KEY=your_openai_api_key
OPENAI_WORKFLOW_MODEL=gpt-4.1-mini
# Optional: set numeric value (e.g. 0.2 or 1). Keep empty for model default.
OPENAI_WORKFLOW_TEMPERATURE=
# OAuth manager
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIN Credentials:
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# installation command for redis server
# from dockrun command
# docker run -d -p 6379:6379 redis
# or
# docker run -d --name autoflow-redis -p 6379:6379 redis:7
#
# Celery worker examples:
# Single worker:
# celery -A celery_config worker -l info -Q workflow.executions,workflow.node_tests,system,celery
#
# Multiple workers (start in separate terminals):
# celery -A celery_config worker -l info -n wf1@%h -Q workflow.executions,celery -c 4
# celery -A celery_config worker -l info -n wf2@%h -Q workflow.executions,celery -c 4
# celery -A celery_config worker -l info -n node@%h -Q workflow.node_tests,celery -c 2
