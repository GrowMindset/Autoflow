# --- Database Configuration ---
# Example: postgresql+asyncpg://user:password@localhost:5432/autoflow
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autoflow

# --- Security ---
# Secret key for JWT token generation. Generate one using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App Settings ---
PORT=8000
DEBUG=True
